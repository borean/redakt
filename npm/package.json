{
  "name": "redakt",
  "version": "0.1.0",
  "description": "Client SDK for the Redakt medical document de-identification API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && tsc --module ESNext --outDir dist/esm && node scripts/bundle.js",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "redakt",
    "de-identification",
    "anonymization",
    "medical",
    "PII",
    "KVKK",
    "privacy",
    "healthcare"
  ],
  "author": "Bora",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/borean/redakt"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
